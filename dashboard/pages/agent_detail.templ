package pages

import (
	"fmt"
	"strconv"
	"github.com/xraph/cortex/agent"
	"github.com/xraph/cortex/run"
	"github.com/xraph/cortex/dashboard/components"
	"github.com/xraph/forgeui/components/card"
	"github.com/xraph/forgeui/components/badge"
	"github.com/xraph/forgeui/components/button"
	"github.com/xraph/forgeui/components/table"
	"github.com/xraph/forgeui/components/separator"
)

templ AgentDetailPage(ag *agent.Config, recentRuns []*run.Run, totalRuns int64, successRate float64, lastRunTime string) {
	<div class="space-y-6">
		@components.PageHeader(ag.Name, "", ag.Description) {
			@button.Button(button.Props{
				Variant: button.VariantOutline,
				Attributes: templ.Attributes{
					"hx-get":    "/agents",
					"hx-target": "#content",
				},
			}) {
				Back
			}
			@button.Button(button.Props{
				Variant: button.VariantOutline,
				Attributes: templ.Attributes{
					"hx-get":    "/agents/edit?name=" + ag.Name,
					"hx-target": "#content",
				},
			}) {
				Edit
			}
			@button.Button(button.Props{
				Variant: button.VariantDestructive,
				Attributes: templ.Attributes{
					"onclick": fmt.Sprintf("tuiOpenDialog('delete-agent-%s')", ag.Name),
				},
			}) {
				Delete
			}
		}
		<div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
			@components.StatCard("play", "Total Runs", strconv.FormatInt(totalRuns, 10), "All time")
			@components.StatCard("check-circle", "Success Rate", fmt.Sprintf("%.0f%%", successRate), "Completed runs")
			@components.StatCard("clock", "Last Run", lastRunTime, "Most recent execution")
			@components.StatCard("layers", "Recent Steps", agentRecentStepCount(recentRuns), "From last 10 runs")
		</div>
		<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
			@card.Card() {
				@card.Header() {
					@card.Title() { Configuration }
				}
				@card.Content() {
					<dl class="grid grid-cols-2 gap-x-4 gap-y-3 text-sm">
						<dt class="text-muted-foreground">ID</dt>
						<dd><code class="text-xs bg-muted px-1.5 py-0.5 rounded">{ ag.ID.String() }</code></dd>
						<dt class="text-muted-foreground">Model</dt>
						<dd class="font-medium">
							if ag.Model != "" {
								{ ag.Model }
							} else {
								<span class="text-muted-foreground">default</span>
							}
						</dd>
						<dt class="text-muted-foreground">Status</dt>
						<dd>@components.EnabledBadge(ag.Enabled)</dd>
						<dt class="text-muted-foreground">Max Steps</dt>
						<dd class="font-medium">{ strconv.Itoa(ag.MaxSteps) }</dd>
						<dt class="text-muted-foreground">Max Tokens</dt>
						<dd class="font-medium">{ strconv.Itoa(ag.MaxTokens) }</dd>
						<dt class="text-muted-foreground">Temperature</dt>
						<dd class="font-medium">{ strconv.FormatFloat(ag.Temperature, 'f', 2, 64) }</dd>
						<dt class="text-muted-foreground">Reasoning Loop</dt>
						<dd class="font-medium">
							if ag.ReasoningLoop != "" {
								{ ag.ReasoningLoop }
							} else {
								<span class="text-muted-foreground">default</span>
							}
						</dd>
						<dt class="text-muted-foreground">Created</dt>
						<dd>
							{{ createdAt := ag.CreatedAt.Format("Jan 02, 2006 15:04:05") }}
							<span class="text-xs text-muted-foreground">{ createdAt }</span>
						</dd>
						<dt class="text-muted-foreground">Updated</dt>
						<dd>
							{{ updatedAt := ag.UpdatedAt.Format("Jan 02, 2006 15:04:05") }}
							<span class="text-xs text-muted-foreground">{ updatedAt }</span>
						</dd>
					</dl>
					if ag.PersonaRef != "" {
						@separator.Separator()
						<div class="mt-4 space-y-2">
							<span class="text-sm font-medium">Persona Reference</span>
							<div>
								<a class="cursor-pointer"
									hx-get={ "/personas/detail?name=" + ag.PersonaRef }
									hx-target="#content">
									@badge.Badge(badge.Props{Variant: badge.VariantSecondary}) {
										{ ag.PersonaRef }
									}
								</a>
							</div>
						</div>
					}
					if len(ag.Tools) > 0 {
						@separator.Separator()
						<div class="mt-4 space-y-2">
							<span class="text-sm font-medium">Tools</span>
							<div class="flex flex-wrap gap-1">
								for _, tool := range ag.Tools {
									@badge.Badge(badge.Props{Variant: badge.VariantOutline}) {
										{ tool }
									}
								}
							</div>
						</div>
					}
					if len(ag.InlineSkills) > 0 {
						@separator.Separator()
						<div class="mt-4 space-y-2">
							<span class="text-sm font-medium">Inline Skills</span>
							<div class="flex flex-wrap gap-1">
								for _, sk := range ag.InlineSkills {
									<a class="cursor-pointer"
										hx-get={ "/skills/detail?name=" + sk }
										hx-target="#content">
										@badge.Badge(badge.Props{Variant: badge.VariantSecondary}) {
											{ sk }
										}
									</a>
								}
							</div>
						</div>
					}
					if len(ag.InlineTraits) > 0 {
						@separator.Separator()
						<div class="mt-4 space-y-2">
							<span class="text-sm font-medium">Inline Traits</span>
							<div class="flex flex-wrap gap-1">
								for _, tr := range ag.InlineTraits {
									<a class="cursor-pointer"
										hx-get={ "/traits/detail?name=" + tr }
										hx-target="#content">
										@badge.Badge(badge.Props{Variant: badge.VariantSecondary}) {
											{ tr }
										}
									</a>
								}
							</div>
						</div>
					}
					if len(ag.InlineBehaviors) > 0 {
						@separator.Separator()
						<div class="mt-4 space-y-2">
							<span class="text-sm font-medium">Inline Behaviors</span>
							<div class="flex flex-wrap gap-1">
								for _, bh := range ag.InlineBehaviors {
									<a class="cursor-pointer"
										hx-get={ "/behaviors/detail?name=" + bh }
										hx-target="#content">
										@badge.Badge(badge.Props{Variant: badge.VariantSecondary}) {
											{ bh }
										}
									</a>
								}
							</div>
						</div>
					}
				}
			}
			@card.Card() {
				@card.Header() {
					@card.Title() { System Prompt }
				}
				@card.Content() {
					if ag.SystemPrompt != "" {
						<pre class="bg-muted rounded-md p-3 text-xs font-mono whitespace-pre-wrap max-h-64 overflow-y-auto">{ ag.SystemPrompt }</pre>
					} else {
						<p class="text-sm text-muted-foreground">No system prompt configured</p>
					}
				}
			}
		</div>
		if len(ag.Guardrails) > 0 {
			@card.Card() {
				@card.Header() {
					@card.Title() { Guardrails }
				}
				@card.Content() {
					@components.JsonViewer(ag.Guardrails)
					if shieldProfile, ok := ag.Guardrails["shield_profile"].(string); ok && shieldProfile != "" {
						@separator.Separator()
						<div class="mt-4 space-y-2">
							<span class="text-sm font-medium">Shield Safety Profile</span>
							<div class="flex items-center gap-2">
								@badge.Badge(badge.Props{Variant: badge.VariantDefault}) {
									{ shieldProfile }
								}
								<a class="text-xs text-muted-foreground hover:underline cursor-pointer"
									hx-get="/safety/profiles"
									hx-target="#content">
									View all profiles
								</a>
							</div>
						</div>
					}
				}
			}
		}
		if len(ag.Metadata) > 0 {
			@card.Card() {
				@card.Header() {
					@card.Title() { Metadata }
				}
				@card.Content() {
					@components.JsonViewer(ag.Metadata)
				}
			}
		}
		@card.Card() {
			@card.Header() {
				@card.Title() { Recent Runs }
			}
			@card.Content() {
				if len(recentRuns) == 0 {
					@components.EmptyState("play", "No runs yet", "Runs for this agent will appear here")
				} else {
					@table.Table() {
						@table.Header() {
							@table.Row() {
								@table.Head() { ID }
								@table.Head() { State }
								@table.Head() { Steps }
								@table.Head() { Created }
								@table.Head() { Action }
							}
						}
						@table.Body() {
							for _, r := range recentRuns {
								@table.Row() {
									@table.Cell() {
										<code class="text-xs bg-muted px-1 py-0.5 rounded">{ r.ID.String() }</code>
									}
									@table.Cell() {
										@components.StateBadge(string(r.State))
									}
									@table.Cell() {
										{ strconv.Itoa(r.StepCount) }
									}
									@table.Cell() {
										{{ created := r.CreatedAt.Format("Jan 02 15:04") }}
										<span class="text-xs text-muted-foreground">{ created }</span>
									}
									@table.Cell() {
										@button.Button(button.Props{
											Variant: button.VariantOutline,
											Size:    button.SizeSm,
											Attributes: templ.Attributes{
												"hx-get":    "/runs/detail?id=" + r.ID.String(),
												"hx-target": "#content",
											},
										}) {
											View
										}
									}
								}
							}
						}
					}
				}
			}
		}
		<!-- Delete Confirmation Dialog -->
		@components.ConfirmDialog(components.ConfirmDialogProps{
			ID:           "delete-agent-" + ag.Name,
			Title:        "Delete Agent",
			Description:  "Are you sure you want to delete agent \"" + ag.Name + "\"? This action cannot be undone.",
			ConfirmLabel: "Delete",
			HxEndpoint:   "/cortex/agents/" + ag.Name,
			HxMethod:     "delete",
		})
		@components.DialogHelpers()
		{ children... }
	</div>
}

func agentRecentStepCount(runs []*run.Run) string {
	total := 0
	for _, r := range runs {
		total += r.StepCount
	}
	return strconv.Itoa(total)
}
